# PostgreSQL
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Spring profile
SPRING_PROFILES_ACTIVE=cloud

# Public backend domain for Caddy automatic HTTPS
DOMAIN=api.example.com

# Frontend origins allowed by backend CORS (comma-separated)
APP_SECURITY_CORS_ALLOWED_ORIGINS=https://app.example.com

# JWT key locations (mount them as files/secrets in EC2)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_PUBLIC_KEY_LOCATION=file:/run/secrets/jwt-public.pem
APP_SECURITY_JWT_PRIVATE_KEY_LOCATION=file:/run/secrets/jwt-private.pem
